# Database (Neon — https://neon.tech)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Auth (Clerk — https://clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Payments (Paddle — https://paddle.com)
# API key: Paddle dashboard → Developer → Authentication
PADDLE_API_KEY=pdl_snd_...
# Webhook secret: Paddle dashboard → Notifications → webhook endpoint
PADDLE_WEBHOOK_SECRET=pdl_ntfset_...
# Price ID for the $29/mo Pro subscription (create in Paddle dashboard as recurring price)
PADDLE_PRO_PRICE_ID=pri_...
# Optional: generic "Digital Product" entity in Paddle (required only if Paddle rejects inline prices)
# PADDLE_PRODUCT_ID=pro_...
# Client-side token for Paddle.js checkout overlay
# Paddle dashboard → Developer → Authentication → Client-side token
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=test_...
# Set to https://api.paddle.com for production; sandbox is the default
PADDLE_API_URL=https://sandbox-api.paddle.com
# Public app origin for checkout redirect URLs
NEXT_PUBLIC_APP_URL=https://creatdrop-sooty.vercel.app

# Email (Resend — https://resend.com)
# API key: Resend dashboard → API Keys
RESEND_API_KEY=re_...
# Verified sender domain; must match a domain you added in Resend
RESEND_FROM_EMAIL=noreply@creatdrop.com

# Error tracking (Sentry — https://sentry.io)
# DSN: Settings → Projects → <project> → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
# Auth token for source map uploads (Sentry → Settings → Auth Tokens)
# Only needed in Vercel — set as SENTRY_AUTH_TOKEN env var in Vercel dashboard
SENTRY_AUTH_TOKEN=

# File storage (Supabase Storage — https://supabase.com/docs/guides/storage)
# Project URL: Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
# Anon/publishable key: Settings → API → Project API keys → anon (sb_publishable_*)
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
# Service role key: Settings → API → Project API keys → service_role (sb_secret_*)
# NEVER expose this in client-side code
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...
